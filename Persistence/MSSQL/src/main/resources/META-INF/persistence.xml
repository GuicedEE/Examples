<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="exampledb">
        <provider>org.hibernate.reactive.provider.ReactivePersistenceProvider</provider>
        <class>com.guicedee.examples.persistence.mssql.entities.User</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url"
                      value="${DB_URL:jdbc:sqlserver://localhost:1433;databaseName=exampledb;trustServerCertificate=true}"/>
            <property name="jakarta.persistence.jdbc.user" value="${DB_USER:sa}"/>
            <property name="jakarta.persistence.jdbc.password" value="${DB_PASSWORD:YourStrong!Passw0rd}"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>

